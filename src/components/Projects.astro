---
import { Image } from 'astro:assets';
import projectFondoverde from '../assets/project-fondoverde.webp';

const PROJECTS = [
    {
        title: "Website de Fondo Verde Internacional",
        description: "Desarrollo y mantenimiento del sitio web institucional utilizando Joomla CMS, asegurando una experiencia de usuario óptima y una gestión eficiente de contenidos.",
        link: "https://www.fondoverde.org/",
        gitgub: "#",
        image: projectFondoverde,
        tags: ["Joomla", "PHP", "SP Page Builder"]
    },
    {
        title: "E-commerce Platform",
        description: "An e-commerce platform with a user-friendly interface, shopping cart functionality, and secure payment integration.",
        link: "#",
        gitgub: "#",
        image: projectFondoverde,
        tags: ["React", "Node.js", "MongoDB"]
    }
]
---
{
    PROJECTS.map(({title, description, image, tags}) => (
        <article>
            <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-purple-300 my-2 mt-4">{title}</h3>
            <p class="text-base sm:text-lg mb-4 font-normal text-gray-600 dark:text-gray-300 text-pretty">{description}</p>
            <ul class="flex gap-x4 flex-row">
                {
                    tags?.map(tag => (
                        <li class="flex gap-x-2 rounded-full text-xs py-2 px-1 background-gray-200 dark:background-gray-700 text-gray-600 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
                            {tag}
                        </li>
                    ))                
                }
            </ul>
            <Image 
                class="rounded-3xl border-3 border-slate-400 shadow-2xl shadow-white/20"
                src={image} alt={`Captura de pantalla del proyecto: ${title}`} 
            />
        </article>
    ))

}