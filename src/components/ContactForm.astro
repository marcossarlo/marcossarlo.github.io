---
---
<div class="flex items-center min-h-screen">
	<div class="container mx-auto">
		<div
			class="max-w-md mx-auto my-10 bg-white dark:bg-gray-800/50 opacity-90 p-5 rounded-lg shadow-md"
		>
			<div class="text-center">
				<h1
					class="my-3 text-3xl font-semibold text-gray-700 dark:text-gray-100"
				>
					Contáctame
				</h1>
				<p class="text-gray-600 dark:text-gray-300">
					Completa el formulario para enviarme un mensaje.
				</p>
			</div>
			<div class="m-7">
				<form action="https://api.web3forms.com/submit" method="POST" id="form">
					<input
						type="hidden"
						name="access_key"
						value="bcd57a86-a37c-41d2-b2b0-824fb4296f0e"
					/>
					<!-- Configuración adicional -->
					<input
						type="hidden"
						name="subject"
						value="Nuevo mensaje desde MarcosSarLo"
					/>
					<input type="hidden" name="from_name" value="MarcosSarLo" />

					<input type="hidden" name="redirect" value={`https://marcossarlo.github.io/submit/exito`} />

					<input type="checkbox" name="botcheck" id="" style="display: none;" />
                    
					<!-- Nombre -->
					<div class="mb-6">
						<label
							for="name"
							class="block mb-2 text-sm text-gray-600 dark:text-white"
							>Nombre Completo <span class="text-red-500">*</span></label
						>
						<input
							type="text"
							name="name"
							id="name"
							placeholder="Pon tu nombre aquí"
							required
							class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:border-gray-600 dark:focus:ring-gray-900 dark:focus:border-gray-500"
						/>
					</div>
					<!-- Correo Electrónico -->
					<div class="mb-6">
						<label
							for="email"
							class="block mb-2 text-sm text-gray-600 dark:text-white"
							>Correo Electrónico <span class="text-red-500"> * </span></label
						>
						<input
							type="email"
							name="email"
							id="email"
							placeholder="Pon un correo válido aquí"
							required
							class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:border-gray-600 dark:focus:ring-gray-900 dark:focus:border-gray-500"
						/>
					</div>
					<!-- Número de Teléfono -->
					<div class="mb-6">
						<label for="phone" class="text-sm text-gray-600 dark:text-white"
							>Número de Teléfono</label
						>
						<input
							type="text"
							name="phone"
							id="phone"
							placeholder="+34 600 123 456"
							class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:border-gray-600 dark:focus:ring-gray-900 dark:focus:border-gray-500"
						/>
					</div>
					<div class="mb-6">
						<label
							for="pais"
							class="block mb-2 text-sm text-gray-600 dark:text-white"
							>País/Ciudad</label
						>
						<input
							type="text"
							name="pais"
							id="pais"
							placeholder="Pon tu país o ciudad"
							class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:border-gray-600 dark:focus:ring-gray-900 dark:focus:border-gray-500"
						/>
					</div>
					<!-- Mensaje -->
					<div class="mb-6">
						<label
							for="message"
							class="block mb-2 text-sm text-gray-600 dark:text-white"
							>Tu Mensaje <span class="text-red-500">*</span></label
						>

						<textarea
							rows="5"
							name="message"
							id="message"
							placeholder="Escribe tu mensaje aquí..."
							class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:border-gray-600 dark:focus:ring-gray-900 dark:focus:border-gray-500"
							required></textarea>
					</div>
					<div class="mb-6">
						<button
							type="submit"
							class="w-full px-3 py-4 text-white bg-indigo-500 rounded-md hover:bg-indigo-600 focus:bg-indigo-600 focus:outline-none"
						>
							Enviar Mensaje
						</button>
					</div>
					<p
						class="text-base text-center text-gray-600 dark:text-gray-400"
						id="result"
					>
					</p>
				</form>
			</div>
		</div>
	</div>
</div>